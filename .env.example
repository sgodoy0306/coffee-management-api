# Environment variables for the Coffee Management API.
# Copy this file to .env and fill in the values for your environment.
# The .env file is listed in .gitignore and must never be committed.

# Spring Boot datasource — used by application.properties
DB_URL=jdbc:postgresql://localhost:4040/coffeedb
DB_USER=brewstack
DB_PASSWORD=brewstack123

# Docker Compose PostgreSQL container — used by docker-compose.yml
POSTGRES_DB=coffeedb
POSTGRES_USER=brewstack
POSTGRES_PASSWORD=brewstack123
